@inherits LayoutComponentBase

<MudThemeProvider Theme="@AppTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">SoloDevBoard</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Text"
                   Color="Color.Inherit"
                   Href="https://learn.microsoft.com/aspnet/core/"
                   Target="_blank"
                   StartIcon="@Icons.Material.Filled.Info">
            About
        </MudButton>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Responsive"
               Elevation="1"
               ClipMode="DrawerClipMode.Always"
               Class="app-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private static readonly MudTheme AppTheme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#3f4a6b",
            Secondary = "#6f7b99",
            Tertiary = "#7f8aa8",
            Background = "#f5f7fb",
            Surface = "#ffffff",
            AppbarBackground = "#3f4a6b",
            AppbarText = "#f6f8ff",
            DrawerBackground = "#edf1f8",
            DrawerText = "#263046",
            TextPrimary = "#232a3a",
            TextSecondary = "#5f6778",
            ActionDefault = "#5f6778",
            ActionDisabled = "#9fa6b7",
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "8px",
        },
    };

    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
