<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@DialogTitle</MudText>
    </TitleContent>

    <DialogContent>
        @if (Content.Mode == LabelOperationMode.Delete)
        {
            <MudText Typo="Typo.body1">Delete label <strong>@Content.OriginalLabelName</strong> from the selected repositories.</MudText>
        }
        else
        {
            <EditForm EditContext="editContext">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <MudTextField @bind-Value="model.LabelName"
                              Label="Label name"
                              Variant="Variant.Outlined"
                              Required="true"
                              data-testid="label-name-input" />
                <ValidationMessage For="@(() => model.LabelName)" />

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-2">
                    <MudColorPicker @bind-Text="model.Colour"
                                    Label="Colour"
                                    ColorPickerMode="ColorPickerMode.HEX"
                                    Variant="Variant.Outlined"
                                    data-testid="label-colour-input" />
                    <MudIcon Icon="@Icons.Material.Filled.Circle"
                             Size="Size.Large"
                             Style="@GetColourPickerIconStyle()"
                             Title="@($"Current colour {ResolveDisplayColour(model.Colour)}")" />
                </MudStack>
                <MudText Typo="Typo.caption">Current colour: @model.DisplayColour</MudText>
                <ValidationMessage For="@(() => model.Colour)" />

                <MudTextField @bind-Value="model.Description"
                              Label="Description"
                              Placeholder="Optional description"
                              Variant="Variant.Outlined"
                              Lines="3"
                              Class="mt-2"
                              data-testid="label-description-input" />
            </EditForm>
        }

        <div class="mt-3" data-testid="dialog-repository-selector">
            <MudText Typo="Typo.subtitle2">Target repositories</MudText>
            @if (Content.Mode != LabelOperationMode.Create)
            {
                <MudText Typo="Typo.caption">Only repositories that already contain this label can be selected.</MudText>
            }

            @foreach (var repository in Content.AvailableRepositories)
            {
                <div>
                    <MudCheckBox T="bool"
                                 Value="selectedRepositoryNames.Contains(repository)"
                                 ValueChanged="isChecked => OnRepositoryToggleChanged(repository, isChecked)"
                                 Disabled="@(!CanSelectRepository(repository))"
                                 Label="@repository" />
                </div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(validationMessage))
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mt-2">@validationMessage</MudAlert>
        }
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="CancelAsync">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="@(Content.Mode == LabelOperationMode.Delete ? Color.Error : Color.Primary)"
                   OnClick="ConfirmAsync">
            @SubmitButtonText
        </MudButton>
    </DialogActions>
</MudDialog>
